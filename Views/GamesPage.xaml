                            <StackPanel>
                                <Image
                                    Margin="14"
                                    VerticalAlignment="Center"
                                    Source="/Assets/Games/Zacmienie/Zacmienie_Logo.png" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Zaćmienie" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="CASBORG" />
                                <RatingControl
                                    Margin="0,0,0,40"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="RatingControl with placeholder"
                                    IsReadOnly="True"
                                    PlaceholderValue="5" />
                                <TextBlock
                                    Grid.Row="0"
