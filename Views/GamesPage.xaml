<Page
    x:Class="SGSClient.Views.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Visible">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="1" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!--<InfoBar IsOpen="True" Margin="0,40,0,0" IsClosable="False" Severity="Error" Title="Uwaga" Message="Używasz wersję testową SGSClienta. Prosimy o zgłaszanie błedów na adres kontakt@szyrgamestudio.com." />-->

                    <TextBlock
                        Grid.Row="0"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Polecane przez SGS" />

                    <!--#region PASEK Z GRAMI POZIOMY (Polecane przez SGS)-->
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Margin="0,0,4,0"
                            Click="ButtonAtorth_Click">
                            <StackPanel>
                                <Image
                                    Margin="14"
                                    VerticalAlignment="Center"
                                    Source="/Assets/Games/Atorth/Atorth_Logo.png" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Atorth: Tales of Ulkimond" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="SZYRGAMESTUDIO" />
                                <RatingControl
                                    Margin="0,0,0,40"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="RatingControl with placeholder"
                                    IsReadOnly="True"
                                    PlaceholderValue="5" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Dostępne" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            Margin="0,0,4,0"
                            Click="ButtonDoddani_Click">
                            <StackPanel>
                                <Image
                                    Margin="14"
                                    VerticalAlignment="Center"
                                    Source="/Assets/Games/Doddani/Doddani_Logo.png" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Doddani" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="SZYRGAMESTUDIO" />
                                <RatingControl
                                    Margin="0,0,0,40"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="RatingControl with placeholder"
                                    IsReadOnly="True"
                                    PlaceholderValue="5" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Dostępne" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <!--#endregion-->

                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock
                            Grid.Row="0"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Pozostałe gry" />
                    </Grid>

                    <!--#region PASEK Z GRAMI POZIOMY-->
                    <Grid Grid.Row="4" Margin="0,12,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Margin="0,0,4,0"
                            Click="ButtonBlackWhiteJump_Click"
                            IsEnabled="True">
                            <StackPanel>
                                <Image
                                    Margin="14"
                                    VerticalAlignment="Center"
                                    Source="/Assets/Games/BlackWhiteJump/Logo.png" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="Black White Jump" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="Dino Jakub" />
                                <RatingControl
                                    Margin="0,0,0,40"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="RatingControl with placeholder"
                                    IsReadOnly="True"
                                    PlaceholderValue="5" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Dostępne" />
                            </StackPanel>
                        </Button>
                        <!--  Bialy Kowal  -->

                        <Button
