                                    Text="Ścieżka Bohatera" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="SZYRROGI" />
                                <RatingControl
                                    Margin="0,0,0,40"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="RatingControl with placeholder"
                                    IsReadOnly="True"
                                    PlaceholderValue="5" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Dostępne" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Column="3"
                            Margin="0,0,4,0"
                            Click="ButtonTurboNinja2D_Click"
                            IsEnabled="True">
                            <StackPanel>
                                <Image
                                    Margin="14"
                                    VerticalAlignment="Center"
                                    Source="/Assets/Games/TurboNinja2D/TurboNinja2D_Logo.png" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Turbo Ninja 2D" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="DEVMASSYN" />
                                <RatingControl
                                    Margin="0,0,0,40"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="RatingControl with placeholder"
                                    IsReadOnly="True"
                                    PlaceholderValue="5" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Dostępne" />
                            </StackPanel>
