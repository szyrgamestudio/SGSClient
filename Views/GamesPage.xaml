                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            Margin="0,0,4,0"
                            Click="ButtonStarmanSystem_Click"
                            IsEnabled="True">
                            <StackPanel>
                                <Image
                                    Margin="14"
                                    VerticalAlignment="Center"
                                    Source="/Assets/Games/StarmanSystem/Logo.png" />
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
